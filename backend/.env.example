# Patent Lawyer App — 환경 변수 설정 파일
# 이 파일을 복사하여 .env 로 저장하고 실제 API 키를 입력하세요.
# .env 파일은 git에 커밋되지 않습니다.

# ── LLM 모델 (최소 1개 필수) ─────────────────────────────────────────────────
# 우선순위: PREFERRED_LLM 설정값 → groq → openai → anthropic → google → mock

# Groq — 완전 무료, LLaMA 3.1 70B | console.groq.com
GROQ_API_KEY=

# OpenAI GPT-4o — 최고 품질 | platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude 3.5 Sonnet | console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini 1.5 Pro | aistudio.google.com
GOOGLE_API_KEY=

# ── 웹 검색 (최소 1개 권장) ────────────────────────────────────────────────────
# Tavily AI Search — 월 1,000건 무료 | tavily.com
TAVILY_API_KEY=

# Serper (Google Search) — 월 2,500건 무료 | serper.dev
SERPER_API_KEY=

# ── 특허 DB (선택, 무료) ──────────────────────────────────────────────────────
# KIPRIS 한국 특허 — 무료 API 신청: open.kipris.or.kr
KIPRIS_API_KEY=

# Lens.org 전세계 특허 — 무료 API 토큰: lens.org
LENS_API_KEY=

# ── 앱 설정 ───────────────────────────────────────────────────────────────────
# Mock 모드 강제 (API 키 없이 테스트용)
MOCK_MODE=false

# 앱 언어 설정 (ko | en)
LANGUAGE=ko

# DB 경로
DATABASE_URL=./patent_app.db
